// x0 SCRATCH
// x1 SCRATCH
// x2 SCRATCH
// x3 Immediate values
// 
//
// x11 Negator flag
// x12 in comment flag

// x20 source pointer
// x21 length of source
// x22 current index
// x23 lookup table
// x24 Accumulator (for numbers)
// x25 left/right switch
// x26 fya64
//   0 = oppcode char
//   4 = left defrefs
//   8 = right defrefs
//  12 = Left index
//  16 = right index
//  20 = left subindex
//  24 = right subindex
// x27 pipe counter
// x28 is immediate flag


// |x2 recived immediates
// |x20 left
// |x21 right
// |x22 types pointer
// |x23 reg pointer
// |x24 reg counter
// |x25 instr pointer
// |x27 qmark value

main:
    stp 29 30 31 -2

    mov  20 0 1     //  x0 TO x20 AS 64bits / Save the source pointer Dirt gave us for the text to X20 to keep it safe
    mov  21 1 1     //  x0 TO x21 AS 64bits / Save the length as well
    movz 22 0 1     //  0  TO x22 AS 64bits / Store our index, starting at zero
    mov  23 2 1     //  x2 TO x23 AS 64bits / Save the lookup table


    movz 11 0 0 //Set the negator to 0
    movz 24 0 0 //Set the accumulator field to zero to start
    movz 25 0 0 //Set the left/right switch to 0
    mov 26 3 1 // Save the fya64 for overflow
    movz 27 0 0 //Set the pipe counter to 0
    movz 28 0 0 //Is immedite flag

    //Process the token stream
    loop: 
        ldrb 0 20 0     //(*x20)+0 TO x0 / Grab the first char from the source text
        ldrb_reg 1 23 0 //(*23)+x0 TO x1 / Retrive the classifer from the lookup table for the char


            movz 3 21 0
            cmp 1 3 0
            b.eq isComment

            movz 3 1 0
            cmp 3 12 0
            b.eq loop_tail //If we're in a comment we just skip over everything

            cmp 1 31 0        // x1 MINUS x31(0) AS 32bits / Check if the classifer is zero or not
            b.eq unclassified // Branch on equals to: if the char's classifier is 0 go to the unclassified handeling

            movz 3 1 0       // 1 TO x3 AS 32bits / Move 1 to register 3, for comparison
            cmp 1 3 0        // x1 MINUS x3 AS 32bits / Check if the classifier is 1 or not
            b.eq isnum       // Branch on equals to: if the char's clasifier is 1 go to isnum

            movz 3 2 0 // Same as above, but with 2 instead of 1, this pattern repeats below
            cmp 1 3 0
            b.eq ispipe 

            movz 3 3 0
            cmp 1 3 0
            b.eq isescape 

            movz 3 4 0
            cmp 1 3 0
            b.eq isopp 

            movz 3 5 0
            cmp 1 3 0
            b.eq isterminator 

            movz 3 6 0
            cmp 1 3 0
            b.eq isP 

            movz 3 7 0
            cmp 1 3 0
            b.eq isI 

            movz 3 8 0
            cmp 1 3 0
            b.eq isS 

            movz 3 9 0
            cmp 1 3 0
            b.eq isDescend 
            
            movz 3 10 0
            cmp 1 3 0
            b.eq isAscend 

            movz 3 11 0
            cmp 1 3 0
            b.eq isReg 
            
            movz 3 12 0
            cmp 1 3 0
            b.eq isBang 

            movz 3 13 0
            cmp 1 3 0
            b.eq isUnderscore 
            
            movz 3 14 0
            cmp 1 3 0
            b.eq isHash 

            movz 3 15 0
            cmp 1 3 0
            b.eq isQmark 

            movz 3 16 0
            cmp 1 3 0
            b.eq isJ 

            movz 3 17 0
            cmp 1 3 0
            b.eq isC 

            movz 3 18 0
            cmp 1 3 0
            b.eq isDash

            movz 3 19 0
            cmp 1 3 0
            b.eq isRangle
            
            movz 3 20 0
            cmp 1 3 0
            b.eq isLangle

            movz 3 22 0
            cmp 1 3 0
            b.eq isLbracket

            movz 3 23 0
            cmp 1 3 0
            b.eq isRbracket

        b loop_tail //Branch: skip to the loop tail if no classification (or lack therforeof) catches the char

        unclassified:
            //Do nothing
        b loop_tail

        isLbracket:
            //Nothing yet
        b loop_tail

        isRbracket:
            //Nothing yet
        b loop_tail

        isComment:
            movz 3 1 0
            cmp 3 12 0
            b.eq in_comment
                movz 12 1 0 //Set comment flag to 1
            b loop_tail

            in_comment:
                movz 12 0 0 //Set comment flag to 0
        b loop_tail
        
        isnum:
            movz 3 48 0      // 48 TO x3 AS 32bits / ASCII offset for 0
            sub 0 0 3 0      // x0 MINUS x3 TO x0 AS 32bits / Convert ASCII to digit value

            // accumulator = accumulator * 10 + digit, we're accumulating for multi digit numbers like 23
            movz 3 10 0      // 10 TO x3 AS 32bits / Moving 10 to 3 for use as a multiplier
            mul 24 24 3 0    // x24 TIMES x3 TO x24 AS 32bits / Shift the accumulator at x24 to the left by 10x

            movz 3 1 0
            mov 1 11 0
            cmp 1 3 0
            b.eq is_negative

                add 24 24 0 0    // x24 PLUS x0 TO x24 AS 32bits / Add new digit
            b loop_tail

            is_negative:
                sub 24 24 0 0   //Subtract instead because we're accumulating negative digits
        b loop_tail

        isDash:
            movz 3 0 0
            mov 1 24 0
            cmp 1 3 0
            b.ne not_negator    //If accumulator isn't 0, skip (because we're a - opp on an immediate)

            mov 1 27 0
            cmp 1 3 0
            b.eq is_negator     //If the pipe counter is 0 and accumulator was 0 then we're a negator not an opp

            not_negator:
                //We're an opperation
            b isopp

            is_negator:
               movz 11 1 0  //Set the negator to 1 
        b loop_tail

        isQmark:
                movz 3 1 0
                mov 1 25 0 //Compare against x25, the left/right flag store to check where we should be
                cmp 1 3 0
            b.eq isQmark_onright //Check if we're emmitting on the left (x20) or right (x21) side

                | mov 20 27 0 //Reads from 27 (where comparison opperators will write)
            b isQmark_tail

            isQmark_onright:
                | mov 21 27 0
            b isQmark_tail

            isQmark_tail:
                movz 24 0 0    //And then clear 24 to reset the accumulator
                movz 11 0 0   //And zero the negator
        b loop_tail

        isRangle:
            ldr32 4 26 8
            movz 3 1 0
            add 4 4 3 0
            str32 4 26 8
        b loop_tail

        isLangle:
            ldr32 4 26 4
            movz 3 1 0
            add 4 4 3 0
            str32 4 26 4
        b loop_tail

        ispipe:
            movz 3 1 0 //Increment the pipe counter
            add 27 27 3 0

            mov 0 24 0 //Move the accumulated number at 24 down to 0 so the syscall can emit it
            emit_movz_imm  //A syscall to emit an instruction that movz the value of x24 as an immediate to 2 (to use for offsets)
                    movz 3 1 0
                    mov 0 25 0 //Compare against x25, the left/right flag store to check where we should be
                    cmp 0 3 0
                b.eq onright //Check if we're emmitting on the left (x20) or right (x21) side
                
                    | ldr32 4 20 8   // Load the element size, which is 8 bytes offset (first 8 bytes are the storage pointer)
                    | mul 2 2 4 0    // Multiply the offset index in 2, which was put in place by the emit_movz_imm, by the element size
                    | ldr 20 20 0        // Follow storage ptr (offset 0) to get into the storage pointer
                    | add 20 20 2 1      // Then add the offset from 2 to get to the element in the storage pointer
                b ispipe_tail

                onright:
                    | ldr32 4 21 8
                    | mul 2 2 4 0
                    | ldr 21 21 0 
                    | add 21 21 2 1    //If we're on the right we're using register 21
                b ispipe_tail

            ispipe_tail:
                movz 24 0 0    //And then clear 24 to reset the accumulator
                movz 11 0 0   //And zero the negator
        b loop_tail

        isI:
                movz 3 1 0
                mov 0 25 0 //Compare against x25, the left/right flag store to check where we should be
                cmp 0 3 0
            b.eq isI_onright //Check if we're emmitting on the left (x20) or right (x21) side
                movz 3 1 0 //Add a left index
                str32 3 26 12
            b loop_tail

            isI_onright:
                movz 3 1 0 //Add a right index
                str32 3 26 16
        b loop_tail


        isS:
                movz 3 1 0
                mov 0 25 0 //Compare against x25, the left/right flag store to check where we should be
                cmp 0 3 0
            b.eq isS_onright //Check if we're emmitting on the left (x20) or right (x21) side
                movz 3 1 0 //Add a left subindex
                str32 3 26 20
            b loop_tail

            isS_onright:
                movz 3 1 0 //Add a right subindex
                str32 3 26 24
        b loop_tail

        isescape:
            //Increment to skip a char
            movz 3 1 0      // 1 TO x3 AS 32bits / Move 1 to register 3, so we can increment with it
            add 20 20 3 1   // x20 PLUS x3 TO x20 AS 64bits / Increment our pointer by one to get to the next char
            add 22 22 3 1   // x22 PLUS x3 TO x22 AS 64bits / Increment the index as well
        b loop_tail 

        isopp:
            str32 0 26 0 //Store the oppcode char
            movz 25 1 0 //Setting the flag to right

            //Checking for an immediate to the left
                movz 3 0 0
                mov 0 27 0
                cmp 0 3 0
                b.eq left_is_immediate    //If the pipe counter is 0, left is an immediate
            b isopp_tail

            left_is_immediate:
                mov 0 24 0
                emit_movz_imm    //Moving the immedite down to be accessible by Acorn
                | mov 20 2 0     //And have Acorn store it at it's left as expected
                movz 28 1 0
            b isopp_tail

        isopp_tail:
            movz 24 0 0 //Clear accumulator
            movz 11 0 0   //And zero the negator
        b loop_tail


        isDescend:
            | movz 3 1 0     //Increment the $ sub index by 1
            | add 24 24 3 0
        b isterminator //Goes down to the terminator end, because it's not an opp

        isAscend:
            | movz 3 1 0      //Decrement the $ sub index by 1
            | sub 24 24 3 0
        b isterminator //Goes down to the terminator end, because it's not an opp


        isReg:
            movz 3 1 0 //Increment the pipe counter
            add 27 27 3 0

            mov 0 24 0 //Move the accumulated number at 24 down to 0 so the syscall can emit it
            emit_movz_imm  //A syscall to emit an instruction that movz the value of x24 as an immediate to 2 (to use for offsets)
                    movz 3 1 0
                    mov 0 25 0 //Compare against x25, the left/right flag store to check where we should be
                    cmp 0 3 0
                b.eq isReg_onright //Check if we're emmitting on the left (x20) or right (x21) side
                
                    | mov 20 23 1        // Move the register pointer into left

                    | ldr32 4 20 8  //Do one regular pipe shift to get to the column
                    | mul 2 2 4 0 
                    | ldr 20 20 0 
                    | add 20 20 2 1

                    | ldr 20 20 0        // Follow storage ptr (offset 0) to get into the storage pointer
                    | movz 4 12 0        // Each reg row is 12 bytes (96bits)
                    | mul 2 24 4 0        // Multiply the passed offset by the reg counter to get to which row we're on
                    | add 20 20 2 1      // Then add the offset from 2 to get to the element in the storage pointer
                b isreg_tail

                isReg_onright:
                    | mov 21 23 1        // Move the register pointer into right

                    | ldr32 4 21 8  //Do one regular pipe shift to get to the column
                    | mul 2 2 4 0 
                    | ldr 21 21 0 
                    | add 21 21 2 1

                    | ldr 21 21 0        // Follow storage ptr (offset 0) to get into the storage pointer
                    | movz 4 12 0        // Each reg row is 12 bytes (96bits)
                    | mul 2 24 4 0        // Multiply the passed offset by the reg counter to get to which row we're on
                    | add 21 21 2 1      // Then add the offset from 2 to get to the element in the storage pointer
                b isreg_tail

            isreg_tail:
                movz 24 0 0    //And then clear 24 to reset the accumulator
                movz 11 0 0   //And zero the negator
        b loop_tail

        isBang:
           movz 3 1 0 //Increment the pipe counter
            add 27 27 3 0

            mov 0 24 0 //Move the accumulated number at 24 down to 0 so the syscall can emit it
            emit_movz_imm  //A syscall to emit an instruction that movz the value of x24 as an immediate to 2 (to use for offsets)
                    movz 3 1 0
                    mov 0 25 0 //Compare against x25, the left/right flag store to check where we should be
                    cmp 0 3 0
                b.eq isBang_onright //Check if we're emmitting on the left (x20) or right (x21) side
                
                    | mov 20 23 1        // Move the register pointer into left

                    | ldr32 4 20 8  //Do one regular pipe shift to get to the column
                    | mul 2 2 4 0 
                    | ldr 20 20 0 
                    | add 20 20 2 1

                    | ldr 20 20 0        // Follow storage ptr (offset 0) to get into the storage pointer
                b isbang_tail

                isBang_onright:
                    | mov 21 23 1        // Move the register pointer into right

                    | ldr32 4 21 8  //Do one regular pipe shift to get to the column
                    | mul 2 2 4 0 
                    | ldr 21 21 0 
                    | add 21 21 2 1

                    | ldr 21 21 0        // Follow storage ptr (offset 0) to get into the storage pointer
                b isbang_tail

            isbang_tail:
                movz 24 0 0    //And then clear 24 to reset the accumulator
                movz 11 0 0   //And zero the negator
        b loop_tail

        isUnderscore:
           movz 3 1 0 //Increment the pipe counter
            add 27 27 3 0

            mov 0 24 0 //Move the accumulated number at 24 down to 0 so the syscall can emit it
            emit_movz_imm  //A syscall to emit an instruction that movz the value of x24 as an immediate to 2 (to use for offsets)
                    movz 3 1 0
                    mov 0 25 0 //Compare against x25, the left/right flag store to check where we should be
                    cmp 0 3 0
                b.eq isUnderscore_onright //Check if we're emmitting on the left (x20) or right (x21) side
                
                    | mov 20 23 1        // Move the register pointer into left

                    | ldr32 4 20 8  //Do one regular pipe shift to get to the column
                    | mul 2 2 4 0 
                    | ldr 20 20 0 
                    | add 20 20 2 1

                    | ldr 20 20 0        // Follow storage ptr (offset 0) to get into the storage pointer
                    | movz 4 12 0        // Each reg row is 12 bytes (96bits)
                    | movz 3 2 0
                    | add 3 3 24
                    | mul 2 3 4 0        // Multiply by the reg counter +1 to go to the row below
                    | add 20 20 2 1      // Then add the offset from 2 to get to the element in the storage pointer
                b isUnderscore_tail

                isUnderscore_onright:
                    | mov 21 23 1        // Move the register pointer into right

                    | ldr32 4 21 8  //Do one regular pipe shift to get to the column
                    | mul 2 2 4 0 
                    | ldr 21 21 0 
                    | add 21 21 2 1

                    | ldr 21 21 0        // Follow storage ptr (offset 0) to get into the storage pointer
                    | movz 4 12 0        // Each reg row is 12 bytes (96bits)
                    | movz 3 2 0
                    | add 3 3 24
                    | mul 2 3 4 0        // Multiply by the reg counter +1 to go to the row below
                    | add 21 21 2 1      // Then add the offset from 2 to get to the element in the storage pointer
                b isUnderscore_tail

            isUnderscore_tail:
                movz 24 0 0    //And then clear 24 to reset the accumulator
                movz 11 0 0   //And zero the negator
        b loop_tail

        isHash:
            movz 3 1 0 //Increment the pipe counter
            add 27 27 3 0

            mov 0 24 0 //Move the accumulated number at 24 down to 0 so the syscall can emit it
            emit_movz_imm  //A syscall to emit an instruction that movz the value of x24 as an immediate to 2 (to use for offsets)
                    movz 3 1 0
                    mov 0 25 0 //Compare against x25, the left/right flag store to check where we should be
                    cmp 0 3 0
                b.eq ishash_onright //Check if we're emmitting on the left (x20) or right (x21) side
                
                    | mov 20 25 1        // Move the instr pointer into left

                    | ldr32 4 20 8  //Do one regular pipe shift to get to the column
                    | mul 2 2 4 0 
                    | ldr 20 20 0 
                    | add 20 20 2 1

                    | ldr 20 20 0        // Follow storage ptr (offset 0) to get into the storage pointer
                    | ldr32 4 20 8       //Get the element  size
                    | mul 2 24 4 0        // Multiply the passed offset by the element size
                    | add 20 20 2 1      // Then add the offset from 2 to get to the element in the storage pointer
                b ishash_tail

                ishash_onright:
                    | mov 21 25 1        // Move the instr pointer into right

                    | ldr32 4 21 8  //Do one regular pipe shift to get to the column
                    | mul 2 2 4 0 
                    | ldr 21 21 0 
                    | add 21 21 2 1

                    | ldr 21 21 0        // Follow storage ptr (offset 0) to get into the storage pointer
                    | ldr32 4 21 8       //Get the element  size
                    | mul 2 24 4 0        // Multiply the passed offset by the element size
                    | add 21 21 2 1      // Then add the offset from 2 to get to the element in the storage pointer
                b ishash_tail

            ishash_tail:
                movz 24 0 0    //And then clear 24 to reset the accumulator
                movz 11 0 0   //And zero the negator
        b loop_tail

        isJ:
            | mov 0 0 0 //A no-op for a placeholder
            mov 0 24 0 //The number value down 
            append_jump
            movz 24 0 0 //Reset accumulator
            movz 11 0 0   //And zero the negator
        b loop_tail

        isC:
            | movz 3 0 0
            | mov 1 27 0 //Compare against x27, for true/false
            | cmp 1 3 0
            | b.eq 2    //Jump 2 if true
            | mov 0 0 0 //A no-op for a placeholder
            mov 0 24 0 //The number value down 
            append_jump
            movz 24 0 0 //Reset accumulator
            movz 11 0 0   //And zero the negator
        b loop_tail

        isP:
            | ldr32 5 20 0 
            | ldr32 6 20 4   
            | ldr32 7 20 8  

            | mov 20 22 1

            | ldr32 4 20 8   // Load the element size, which is 8 bytes offset (first 8 bytes are the storage pointer)
            | mul 2 5 4 0    // Multiply the offset index in 5, which was put in place by the emit_movz_imm, by the element size
            | ldr 20 20 0        // Follow storage ptr (offset 0) to get into the storage pointer
            | add 20 20 2 1      // Then add the offset from 5 to get to the element in the storage pointer

            | ldr32 4 20 8   // Load the element size, which is 8 bytes offset (first 8 bytes are the storage pointer)
            | mul 2 6 4 0    // Multiply the offset index in 6, which was put in place by the emit_movz_imm, by the element size
            | ldr 20 20 0        // Follow storage ptr (offset 0) to get into the storage pointer
            | add 20 20 2 1      // Then add the offset from 6 to get to the element in the storage pointer

            | ldr32 4 20 8   // Load the element size, which is 8 bytes offset (first 8 bytes are the storage pointer)
            | mul 2 7 4 0    // Multiply the offset index in 7, which was put in place by the emit_movz_imm, by the element size
            | ldr 20 20 0        // Follow storage ptr (offset 0) to get into the storage pointer
            | add 20 20 2 1      // Then add the offset from 7 to get to the element in the storage pointer

            | stp 29 30 31 -2
            | blr 20
            | ldp 29 30 31 2

            movz 24 0 0   //Reset accumulator
            movz 11 0 0   //And zero the negator
        b loop_tail

        isterminator:
            // |x20 = resolved left address
            // |x21 = resolved right address  
            // x26 = opcode char
            
                movz 3 0 0
                ldr32 13 26 4
                cmp 13 3 0
                b.eq skip_left_defrefs

                loop_left_defrefs: 
                    | ldr32 5 20 0 
                    | ldr32 6 20 4   
                    | ldr32 7 20 8  
   
                    | mov 20 22 1

                    | ldr32 4 20 8   // Load the element size, which is 8 bytes offset (first 8 bytes are the storage pointer)
                    | mul 2 5 4 0    // Multiply the offset index in 5, which was put in place by the emit_movz_imm, by the element size
                    | ldr 20 20 0        // Follow storage ptr (offset 0) to get into the storage pointer
                    | add 20 20 2 1      // Then add the offset from 5 to get to the element in the storage pointer

                    | ldr32 4 20 8   // Load the element size, which is 8 bytes offset (first 8 bytes are the storage pointer)
                    | mul 2 6 4 0    // Multiply the offset index in 6, which was put in place by the emit_movz_imm, by the element size
                    | ldr 20 20 0        // Follow storage ptr (offset 0) to get into the storage pointer
                    | add 20 20 2 1      // Then add the offset from 6 to get to the element in the storage pointer

                    | ldr32 4 20 8   // Load the element size, which is 8 bytes offset (first 8 bytes are the storage pointer)
                    | mul 2 7 4 0    // Multiply the offset index in 7, which was put in place by the emit_movz_imm, by the element size
                    | ldr 20 20 0        // Follow storage ptr (offset 0) to get into the storage pointer
                    | add 20 20 2 1      // Then add the offset from 7 to get to the element in the storage pointer
                ldr32 4 26 4
                movz 3 1 0
                sub 4 4 3 0 //Subtract from the left defrefs count and loop
                str32 4 26 4
                movz 3 0 0
                cmp 4 3 0
                b.gt loop_left_defrefs
            skip_left_defrefs:

                movz 3 0 0
                ldr32 14 26 8
                cmp 14 3 0
                b.eq skip_right_defrefs

                loop_right_defrefs:       
                    | ldr32 5 21 0 
                    | ldr32 6 21 4   
                    | ldr32 7 21 8  

                    | mov 21 22 1

                    | ldr32 4 21 8
                    | mul 2 5 4 0
                    | ldr 21 21 0
                    | add 21 21 2 1

                    | ldr32 4 21 8
                    | mul 2 6 4 0
                    | ldr 21 21 0
                    | add 21 21 2 1

                    | ldr32 4 21 8
                    | mul 2 7 4 0
                    | ldr 21 21 0
                    | add 21 21 2 1

                ldr32 4 26 8
                movz 3 1 0
                sub 4 4 3 0
                str32 4 26 8
                movz 3 0 0
                cmp 4 3 0
                b.gt loop_right_defrefs
            skip_right_defrefs:

                //Left index
                ldr32 4 26 12
                movz 3 0 0
                cmp 4 3 0
                b.eq skip_left_index
                    | movz 2 4 0
                    | add 20 20 2 1
                skip_left_index:

                //Right index
                ldr32 4 26 16
                movz 3 0 0
                cmp 4 3 0
                b.eq skip_right_index
                    | movz 2 4 0
                    | add 21 21 2 1
                skip_right_index:

                //Left subindex
                ldr32 4 26 20
                movz 3 0 0
                cmp 4 3 0
                b.eq skip_left_subindex
                    | movz 2 8 0
                    | add 20 20 2 1
                skip_left_subindex:

                //Right subindex
                ldr32 4 26 24
                movz 3 0 0
                cmp 4 3 0
                b.eq skip_right_subindex
                    | movz 2 8 0
                    | add 21 21 2 1
                skip_right_subindex:

            ldr32 4 26 0 //Retrive the char

            movz 3 61 0
            cmp 4 3 0
            b.eq emit_equals

            movz 3 62 0
            cmp 4 3 0
            b.eq emit_rangle

            movz 3 43 0
            cmp 4 3 0
            b.eq emit_plus

            movz 3 45 0
            cmp 4 3 0
            b.eq emit_sub

            movz 3 76 0
            cmp 4 3 0
            b.eq emit_l

            movz 3 69 0
            cmp 4 3 0
            b.eq emit_e

            b emit_done

            emit_equals:
                movz 3 1 0
                cmp 28 3 0
                b.eq isimm_equals

                //If not an immediate
                    | ldr 3 20 0
                    | str32 3 21 0
                b emit_equals_tail

                isimm_equals:
                    | str32 20 21 0 //If immedite
                    movz 28 0 0 //Flag off immediate
                b emit_equals_tail

                emit_equals_tail:
                    //nothing here
            b emit_done

            emit_plus:
                movz 3 1 0
                cmp 28 3 0
                b.eq isimm_plus

                //If not an immediate
                    | ldr32 3 20 0
                    | ldr32 4 21 0
                    | add 3 3 4 0
                    | str32 3 21 0
                b emit_plus_tail

                isimm_plus:
                    | ldr32 4 21 0
                    | add 3 20 4 0
                    | str32 3 21 0
                    movz 28 0 0 //Flag off immediate
                b emit_plus_tail

                emit_plus_tail:
                    //nothing here
            b emit_done


            emit_sub:
                movz 3 1 0
                cmp 28 3 0
                b.eq isimm_sub

                //If not an immediate
                    | ldr32 3 20 0
                    | ldr32 4 21 0
                    | sub 3 4 3 0
                    | str32 3 21 0
                b emit_sub_tail

                isimm_sub:
                    | ldr32 4 21 0
                    | sub 3 4 20 0
                    | str32 3 21 0
                    movz 28 0 0 //Flag off immediate
                b emit_sub_tail

                emit_sub_tail:
                    //nothing here
            b emit_done

            emit_l:
                movz 3 1 0
                cmp 28 3 0
                b.eq isimm_l

                //If not an immediate
                    | ldr32 3 20 0
                    | ldr32 4 21 0
                    | cmp 3 4 0
                    | cset.lt 27
                b emit_l_tail

                isimm_l:
                    | ldr32 4 21 0
                    | cmp 20 4 0
                    | cset.lt 27
                    movz 28 0 0 //Flag off immediate
                b emit_l_tail

                emit_l_tail:
                    //nothing here
            b emit_done

            //Not usable yet!
            emit_u:
                movz 3 1 0
                cmp 28 3 0
                b.eq isimm_u

                //If not an immediate
                    | ldr32 3 20 0
                    | ldr32 4 21 0
                    | cmp 3 4 0
                    | cset.ge 27
                b emit_u_tail

                isimm_u:
                    | ldr32 4 21 0
                    | cmp 20 4 0
                    | cset.ge 27
                    movz 28 0 0 //Flag off immediate
                b emit_u_tail

                emit_u_tail:
                    //nothing here
            b emit_done

            emit_e:
                movz 3 1 0
                cmp 28 3 0
                b.eq isimm_e

                //If not an immediate
                    | ldr32 3 20 0
                    | ldr32 4 21 0
                    | cmp 3 4 0
                    | cset.eq 27
                b emit_e_tail

                isimm_e:
                    | ldr32 4 21 0
                    | cmp 20 4 0
                    | cset.eq 27
                    movz 28 0 0 //Flag off immediate
                b emit_e_tail

                emit_e_tail:
                    //nothing here
            b emit_done

            emit_done:
                //Reset the registers
                | mov 20 22 1 
                | mov 21 22 1 
                movz 25 0 0   //Reset side flag to left
                movz 3 0 0
                str32 3 26 0   //Clear opcode register
                str32 3 26 4    //Clear langle
                str32 3 26 8   //Clear rangle

                //Clear index and subindex
                str32 3 26 12
                str32 3 26 16
                str32 3 26 20
                str32 3 26 24

                movz 27 0 0   //Reset pipe counter
                resolve_terminator
        b loop_tail

        loop_tail:
            // Increment pointer and index
            movz 3 1 0      // 1 TO x3 AS 32bits / Move 1 to register 3, so we can increment with it
            add 20 20 3 1   // x20 PLUS x3 TO x20 AS 64bits / Increment our pointer by one to get to the next char
            add 22 22 3 1   // x22 PLUS x3 TO x22 AS 64bits / Increment the index as well

            cmp 22 21 1    // x22 MINUS x21 AS 64bits / Check if index (x22) is less than length (x21)

    b.lt loop           // Branch on less than: if the index is less than the length, loop again

    wub //For security reasons
    ldp 29 30 31 2
ret