div displaytext(string words, div sub {}, string othercolor, string target) {
    text words {
        target : othercolor;
    }
    sub;
}

"/" {
    displaytext("nothing",div thungy{
        text "thungy" {
            "color" : "blue";
        }
        text "otter";
    },"green","background-color");
}

"/a" {
    displaytext("something",div thingy{
        text "thingy" {
            "color" : "red";
        }
        text "otter" {
            "color" : "yellow";
        }
    },"blue","color");
}

server {
    port(8081);
    listen {
        accept;
        request;
        response;
        close;
    }
}