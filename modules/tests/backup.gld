" #255d25"
" #FFD700"

style nav_style {
    "background-color" : "rgb(25, 50, 20)";
    "width" : "100%";
    "padding" : "clamp(4px, 1.5vw, 8px)";
    "position" : "fixed";
    "top" : "0";
    "display" : "flex";
    "align-items" : "center";
    "gap" : "clamp(8px, 2vw, 16px)";
    "box-sizing" : "border-box";
}

style nav_title_style {
    "font-size" : "clamp(28px, 2.5vw, 34px)";
    "color" : "rgb(237, 210, 0)";
    "font-family" : "Georgia, serif";
    "font-weight" : "bold";
    "cursor" : "pointer";
}

style nav_link_style {
    "font-size" : "clamp(18px, 1.5vw, 26px)";
    "color" : " rgb(237, 210, 0)";
    "font-family" : "Georgia, serif";
    "cursor" : "pointer";
}

style page_style {
    "background-color" : "rgb(23, 23, 23)";
    "min-height" : "100vh";
    "margin" : "0";
}



nav_bar {
    nav_style;
    paragraph "Golden" {
        nav_title_style;
        "onclick" : "goTo('/')";
    }
    paragraph "Poetry" {
        nav_link_style;
        "onclick" : "goTo('/poetry')";
    }
    paragraph "Projects" {
        nav_link_style;
        "onclick" : "goTo('/projects')";
    }
    paragraph "GEMS" {
        nav_link_style;
        "onclick" : "goTo('/GEMS')";
    }

    script "
        function goTo(route) {
            window.location.href = route;
        }
    ";
}

style container_style {
    "position" : "relative";
    "height" : "300vh";
}

style default_button {
    height : "16px";
    width  : "15px";
    "background-color" : "red";
}

"/" {
    page_style;

    nav_bar;

    style big_center_a {
        "font-size" : "48px";
        "color" : "rgb(228, 228, 228)";
        "text-align" : "center";
        "margin-top" : "20%";
        "position" : "relative";
        "width" : "100%";
        "opacity" : "1";
        "transition" : "opacity 0.5s ease";
    }

    style big_center_b {
        "font-size" : "48px";
        "color" : "rgb(228, 228, 228)";
        "text-align" : "center";
        "margin-top" : "20%";
        "position" : "relative";
        "width" : "100%";
        "opacity" : "0";
        "transition" : "opacity 0.5s ease";
    }

    style circle_style {
        "width" : "100px";
        "height" : "100px";
        "border-radius" : "50%";
        "background-color" : "black";
        "position" : "absolute";
    }

   container {
        container_style;
        paragraph read_file("wubtext.txt") {
            big_center_a;
            "id" : "center_text_a"
        }
        paragraph read_file("nubtext.txt") {
            big_center_b;
            "id" : "center_text_b"
        }
        orbit_circle { 
            circle_style;
            onclick : "handleClick()";
        }
    }

    button submit {
        id : submit;
        onclick : "frag('center_text_a')";
        default_button;
    }

    script read_file("frag.js");

    script "
        window.addEventListener('scroll', () => {
            const angle = window.scrollY * 0.01;
            const radius = 150;
            const container = document.getElementById('container');
            const centerX = container.offsetWidth / 2;
            const centerY = 200;
            const x = centerX + Math.cos(angle) * radius;
            const y = centerY + Math.sin(angle) * radius;
            const circle = document.getElementById('orbit_circle');
            circle.style.left = x + 'px';
            circle.style.top = y + 'px';

            const circleRect = circle.getBoundingClientRect();
            const textRect = document.getElementById('center_text_a').getBoundingClientRect();
            const overlapping = !(circleRect.right < textRect.left ||
                                circleRect.left > textRect.right ||
                                circleRect.bottom < textRect.top ||
                                circleRect.top > textRect.bottom);

            document.getElementById('center_text_a').style.opacity = overlapping ? 0 : 1;
            document.getElementById('center_text_b').style.opacity = overlapping ? 1 : 0;
        });

        function handleClick() {
            const text = document.getElementById('center_text_b');
            text.innerHTML += '<br>Wub';
        }
    ";
}


"/poetry" {
    page_style;

    nav_bar;

    style poem_style {
        "font-size" : "clamp(16px, 1.8vw, 22px)";
        "font-family" : "Georgia, serif";
        "color" : "rgb(228, 228, 228)";
        "line-height" : "1.8";
        "white-space" : "pre-wrap";
        "max-width" : "1200px";
        "margin" : "120px auto 60px auto";
        "padding" : "0 24px";
    }

    container {
        paragraph read_file("poems.txt") {
            poem_style;
        }
    }
}


"/projects" {
    page_style;

    nav_bar;
}

"/GEMS" {
    page_style;

    nav_bar;
}

server {
    port(8080);
    listen {
        accept;
        request;
        response;
        close;
    }
}
