formed type GEMS_RB {
    int one {
        3; onform "Wumbers" {
            "Default" : 0;
            "First" : 1;
            "Second" : 2;
            "Third" : 3;
            "Fourth" : 4;
            "Fifth" : 5;
        }
        4; 
        5; 
        6;
    }

    int two {
        6; 
        7; onform "Twumbers" {
            "Default" : 0;
            "Firsty" : 11;
            "Secondy" : 22;
            "Thirdy" : 33;
        }
        8; 
        9;
    }

    string names {
        "alex"; "axel"; "bob";
    }

    qscript int isthree {
        "1+2";
    }
}

"/" {
    form(GEMS_RB);
    sheet(GEMS_RB);
    script read_file("frag.js");

    in posting {
        recive_sheet_edit;
    }
}


server {
    port(8081);
    listen {
        accept;
        request;
        response;
        close;
    }
}