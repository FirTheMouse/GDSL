formed type GEMS_RB {
    int one {
        3; onform "Wumbers" {
            "First" : 1;
            "Second" : 2;
            "Third" : 3;
            "Fourth" : 4;
            "Fifth" : 5;
        }
        4; 
        5; 
        6;
    }

    int two {
        6; 
        7; onform "Twumbers" {
            "Firsty" : 11;
            "Secondy" : 22;
            "Thirdy" : 33;
        }
        8; 
        9;
    }

    string names {
        "alex"; "axel"; "bob";
    }
}

calculator type TESTING {
    int non_taxable_portion {
        0; onform "Non-taxable portion";
    }
    int total_ammount {
        0; onform "Total ammount";
    }
    string taxable_base {
        "total_amount-non_taxable_portion";
    }
    string provience {
        "ON"; onform "Provience" {
                "ON" : "ON";
                "PEI" : "PEI";
                "QEB" : "QEB";
        } 
    }
    string hst_rate {
        "
        float hst;
        if(provience=="ON") {hst=0.13;}
        if(provience=="PEI") {hst=0.15;}
        if(provience=="QEB") {hst=0.07;}
        ";
    }
    GQL string from_gems {
        "
            find ( first in GEMS_RB where label "one" and as int greaterthan 6 );
        ";
    }
    string hst_ammount {
        "taxable_base*hst_rate";
    }
    float recapture_rate {
        0.0; onform "Recapture rate";
    }
    string itc_recapture {
        "hst_amount*recapture_rate";
    }
    string net_itc {
        "hst_amount-itc_recapture";
    }
}


to_disk(GEMS_RB,"saved/gems_rb.gld");
to_disk(GEMS_RB_FORM,"saved/gems_rb_form.gld");