    | movz 15 4 0
            | mov 20 21 1
            | ldr32 5 20 0 
            | ldr32 6 20 4   
            | ldr32 7 20 8  

            | mov 20 22 1

            | ldr32 4 20 8   // Load the element size, which is 8 bytes offset (first 8 bytes are the storage pointer)
            | mul 2 5 4 0    // Multiply the offset index in 5, which was put in place by the emit_movz_imm, by the element size
            | ldr 20 20 0        // Follow storage ptr (offset 0) to get into the storage pointer
            | add 20 20 2 1      // Then add the offset from 5 to get to the element in the storage pointer

            | ldr32 4 20 8   // Load the element size, which is 8 bytes offset (first 8 bytes are the storage pointer)
            | mul 2 6 4 0    // Multiply the offset index in 6, which was put in place by the emit_movz_imm, by the element size
            | ldr 20 20 0        // Follow storage ptr (offset 0) to get into the storage pointer
            | add 20 20 2 1      // Then add the offset from 6 to get to the element in the storage pointer

            | ldr32 4 20 8   // Load the element size, which is 8 bytes offset (first 8 bytes are the storage pointer)
            | mul 2 7 4 0    // Multiply the offset index in 7, which was put in place by the emit_movz_imm, by the element size
            | ldr 20 20 0        // Follow storage ptr (offset 0) to get into the storage pointer
            | add 20 20 2 1      // Then add the offset from 7 to get to the element in the storage pointer

