inlined socket_btn_theme {
    "padding" : "8px 16px";
    "background-color" : "rgb(68, 137, 50)";
    "border" : "none";
    "border-radius" : "4px";
    "width" : "10%";
    "font-family" : "monospace";
    "cursor" : "pointer";
    "flex" : "1";
}


"/" {  
    "background-color" : "rgb(47, 46, 46)";
    style "
        span { color : rgb(200, 200, 200); }
        .text { color:rgb(255, 152, 0); }
        .style { color:rgb(255, 152, 0); }
        .inlined { color: rgb(155, 155, 155); }
        .component { color: rgb(57, 123, 222); }
        .FUNC_DECL { color:rgb(33, 150, 243); }
        .LBRACE, .RBRACE { color:rgb(134, 135, 135); }
        .VAR_DECL { color: rgb(152, 171, 239); }
        .LITERAL { color:rgb(255, 112, 60); }
        .QUOTE { color:rgb(255, 112, 60); }
        .IDENTIFIER { color:rgb(106, 106, 152); }
        .COLON { color: #ffffff; }

        input:focus {
            outline: none;
        }

        div {
            outline: none;
        }
    ";


    div container {
        "display" : "flex";
        "flex-direction" : "column";
        "gap" : "12px";
        "height" : "100vh";
        "overflow" : "hidden";
            div top_bar {
                "display" : "flex";
                "justify-content" : "space-between";
                "align-items" : "center";
                "padding" : "16px 14px";
                "background-color" : "rgb(105, 81, 66)";
                
                div menu_items {
                    "display" : "flex";
                    "gap" : "16px";
                    "color" : "rgb(200,200,200)";
                    "font-family" : "monospace";
                    "font-size" : "13px";
                }

                button load_btn {
                    "onclick" : "load_file('pebblesave.gld')";
                    "padding" : "8px 16px";
                    "background-color" : "rgb(68, 137, 50)";
                    "border" : "none";
                    "border-radius" : "4px";
                    "font-family" : "monospace";
                    "cursor" : "pointer";
                }

                button save_btn {
                    "onclick" : "save_file('pebblesave.gld')";
                    "padding" : "8px 16px";
                    "background-color" : "rgb(68, 137, 50)";
                    "border" : "none";
                    "border-radius" : "4px";
                    "font-family" : "monospace";
                    "cursor" : "pointer";
                }
            }

            div editor {
                "display" : "flex";
                "min-height" : "0";
                "overflow-y" : "auto";
                "gap" : "12px";
                "flex" : "1";
                    div code {
                        "flex" : "1";
                        "width" : "100%";
                        "min-height" : "0";
                        "overflow-y" : "auto";
                        "border-radius" : "12px";
                        "box-shadow" : "0 4px 24px rgba(0,0,0,0.08)";
                        
                        "color" : "rgb(200,200,200)";
                        "id" : "code";
                        "contenteditable" : "true";
                        "font-family" : "monospace";
                        "white-space" : "pre";
                        "padding" : "10px 14px";
                        "background-color" : "rgb(30, 30, 30)";
                    }

                    div display_panel {
                        "flex" : "1";
                        "width" : "100%";
                        "padding" : "10px";
                        "border-radius" : "12px";
                        "box-shadow" : "0 4px 24px rgba(0,0,0,0.08)";
                        "background-color" : "rgb(10, 10, 10)";

                        div first_socket {
                            "flex" : "1";
                            "height" : "50%";
                            div control_btns {
                                "display" : "flex";
                                "justify-content" : "center";
                                "align-items" : "center";
                                button open_btn {
                                    "onclick" : "compile_preview('first_preview')";
                                    "background-color" : "rgb(68, 137, 50)";
                                    socket_btn_theme;
                                }
                                
                                button close_btn {
                                    "onclick" : "end_preview('first_preview')";
                                    "background-color" : "rgb(137, 50, 50)";
                                    socket_btn_theme;
                                }
                            }
                            iframe first_preview {
                                "id":"first_preview";
                                "width" : "100%";
                                "height" : "100%";
                            }
                        }

                        div second_socket {
                            "flex" : "1";
                            "height" : "50%";
                            div control_btns {
                                "display" : "flex";
                                "justify-content" : "center";
                                "align-items" : "center";
                                button open_btn {
                                    "onclick" : "compile_preview('second_preview')";
                                    "background-color" : "rgb(68, 137, 50)";
                                    socket_btn_theme;
                                }
                                
                                button close_btn {
                                    "onclick" : "end_preview('second_preview')";
                                    "background-color" : "rgb(137, 50, 50)";
                                    socket_btn_theme;
                                }
                            }
                            iframe second_preview {
                                "id":"second_preview";
                                "width" : "100%";
                                "height" : "100%";
                            }
                        }
                    }


            }
    }

    in fragmenting {
        fragment_highlight;
    }

    in posting {
        pebble_post;
    }

    script read_file("frag.js");
    script read_file("cursor.js");
}


server {
    port(8080);
    listen {
        accept;
        request;
        response;
        close;
    }
}