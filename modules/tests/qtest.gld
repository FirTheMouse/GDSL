"test" {
    in executing {  
        Node n;
        Node v;
        n.type = int.type;
        v.node_table << n("one");
        node.node_table = v.node_table;
        Node j = n;
        print(j);
        store s;
        s << v.node_table("one");
        node.children << s(0);
        j = v;
        print(j);
        print(node);
    }
}

travel_pass executing {
    test(1);
}